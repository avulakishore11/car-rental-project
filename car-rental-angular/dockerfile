# Stage 1: Build Angular App
FROM node:20 AS builder

WORKDIR /app
COPY car-rental-angular/package*.json ./
WORKDIR /app/car-rental-angular
RUN npm install --frozen-lockfile
COPY car-rental-angular/ .
RUN npm run build --configuration=production

# Stage 2: NGINX Web Server
FROM nginx:alpine

# Clear default nginx content
RUN rm -rf /usr/share/nginx/html/*

# Copy built Angular files from builder
COPY --from=builder /app/car-rental-angular/dist/car-rental-angular /usr/share/nginx/html

# Optional: custom SPA routing config
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
